# LINE Login 設定
# 至 https://developers.line.biz 建立 LINE Login channel 後填入
LINE_CLIENT_ID=your_line_channel_id
LINE_CLIENT_SECRET=your_line_channel_secret

# 登入後導回的網址 (開發環境)
LINE_REDIRECT_URI=http://localhost:3000/auth/line/callback

# Session 密鑰 (請改成隨機字串)
SESSION_SECRET=change-this-to-a-random-secret-string

# 伺服器端口
PORT=3000
